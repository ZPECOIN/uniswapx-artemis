# UniswapX Artemis Configuration
# Copy this file to .env and fill in your values

# Ethereum Network Configuration
# HTTP RPC endpoint (required)
RPC_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key
# WebSocket RPC endpoint (optional but recommended)
RPC_WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/your-api-key

# Chain Configuration
CHAIN_ID=1

# Private Key Management (choose one method)
# Method 1: Direct private key (not recommended for production)
PRIVATE_KEY=your-private-key-here

# Method 2: Private key file path
# PRIVATE_KEY_FILE=/path/to/keyfile.json

# Method 3: AWS Secrets Manager ARN (recommended for production)
# AWS_SECRET_ARN=arn:aws:secretsmanager:region:account:secret:name

# Executor Configuration
# The address of your deployed executor contract
EXECUTOR_ADDRESS=0x1234567890abcdef1234567890abcdef12345678

# Order Type: Priority, DutchV2, or DutchV3
ORDER_TYPE=DutchV3

# Strategy Configuration
# Percentage of profit to pay in gas (default: 1-10)
BID_PERCENTAGE=5

# Determines how aggressive to scale the fallback bids (100 = 1% of profit)
FALLBACK_BID_SCALE_FACTOR=100

# Minimum block percentage buffer for priority orders (120 = 120% of block time)
MIN_BLOCK_PERCENTAGE_BUFFER=120

# Optional: UniswapX API Configuration
# UNISWAPX_API_KEY=your-uniswapx-api-key

# AWS Configuration (required if using CloudWatch or AWS secrets)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Enable CloudWatch metrics (true/false)
CLOUDWATCH_METRICS=false

# Logging Configuration
LOG_LEVEL=info