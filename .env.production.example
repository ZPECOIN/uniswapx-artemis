# Production Environment Configuration
RPC_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/your-prod-api-key
RPC_WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/your-prod-api-key

CHAIN_ID=1
ORDER_TYPE=DutchV3
BID_PERCENTAGE=3
CLOUDWATCH_METRICS=true
LOG_LEVEL=info

# Use AWS Secrets Manager for production
AWS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:artemis-private-key-ABC123
AWS_REGION=us-east-1

EXECUTOR_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
UNISWAPX_API_KEY=your-production-api-key